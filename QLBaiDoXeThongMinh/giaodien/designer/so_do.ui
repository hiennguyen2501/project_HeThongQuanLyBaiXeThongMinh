}
QLabel#freeSwatch,
QLabel#occupiedSwatch,
QLabel#freeSwatch2,
QLabel#occupiedSwatch2 {
    min-width: 24px;
    min-height: 24px;
    max-width: 24px;
    max-height: 24px;
    border-radius: 6px;
}
QLabel#freeSwatch,
QLabel#freeSwatch2 {
    background: #16A34A;
}
QLabel#occupiedSwatch,
QLabel#occupiedSwatch2 {
