}
QTabWidget::pane {
    background: #FFFFFF;
    border: 1px solid #D8E0EA;
    border-radius: 8px;
    top: -1px;
}
QTabBar::tab {
    background: #E8EEF6;
    color: #526173;
    padding: 12px 32px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    margin-right: 4px;
    font-size: 15px;
    font-weight: 700;
    min-width: 160px;
}
QTabBar::tab:selected {
    background: #176BFF;
    color: #FFFFFF;
}
QPushButton#btn_quay_ve {
    background: #475569;
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 8px 18px;
    font-size: 13px;
    font-weight: 700;
    min-height: 36px;
}
QPushButton#btn_quay_ve:hover {
    background: #334155;
}
QFrame#floorPanel,
QFrame#legendPanel {
    background: #FFFFFF;
    border: 1px solid #D8E0EA;
    border-radius: 8px;
}
QWidget#widget_so_do,
QWidget#widget_so_do_b2 {
    background: #F8FAFC;
